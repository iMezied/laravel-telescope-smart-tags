{
    "name": "imezied/telescope-smart-tags",
    "description": "Smart, configurable auto-tagging for Laravel Telescope — tag requests by HTTP status, exceptions, slow response times, route groups, and more.",
    "keywords": ["laravel", "telescope", "debugging", "tagging", "monitoring", "observability"],
    "homepage": "https://github.com/imezied/telescope-smart-tags",
    "license": "MIT",
    "authors": [
        {
            "name": "iMezied",
            "email": "imezied@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/telescope": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Imezied\\TelescopeSmartTags\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imezied\\TelescopeSmartTags\\Tests\\": ""
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Imezied\\TelescopeSmartTags\\TelescopeSmartTagsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
